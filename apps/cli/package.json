{
  "name": "xtarterize",
  "version": "0.1.0",
  "description": "Automated project setup and configuration scaffolding",
  "author": "agustinusnathaniel",
  "license": "MIT",
  "type": "module",
  "bin": {
    "xtarterize": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "citty": "^0.1.6"
  },
  "devDependencies": {
    "@types/node": "^24.1.0",
    "@xtarterize/core": "workspace:*",
    "@xtarterize/tasks": "workspace:*",
    "tsdown": "^0.21.9",
    "typescript": "^5.9.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/agustinusnathaniel/xtarterize"
  },
  "homepage": "https://xtarterize.sznm.dev",
  "bugs": {
    "url": "https://github.com/agustinusnathaniel/xtarterize/issues"
  },
  "keywords": [
    "scaffold",
    "starter",
    "template",
    "cli",
    "project-setup",
    "boilerplate"
  ]
}
